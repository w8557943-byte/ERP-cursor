.workorder-page {
  min-height: 100vh;
  background-color: #f3f4f6;
  display: flex;
  flex-direction: column;
  font-family: "SimHei", "Microsoft YaHei", sans-serif;
}

.header {
  padding: 24rpx 32rpx;
}

.title {
  font-size: 32rpx;
  font-weight: 600;
  color: #111827;
}

.content {
  flex: 1;
  padding: 0 24rpx 24rpx;
}

.preview-root {
  width: 100%;
  display: flex;
  justify-content: center;
}

.pages {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
  width: 100%;
}

.ticket {
  width: 640rpx;
  box-sizing: border-box;
  background-color: #ffffff;
  border-radius: 0;
  padding: 28rpx 28rpx 24rpx;
  box-shadow: none;
  display: flex;
  flex-direction: column;
}

.ticket-header {
  display: flex;
  flex-direction: column;
  margin-bottom: 16rpx;
}

.ticket-title {
  font-size: 40rpx;
  font-weight: 700;
  text-align: center;
  margin-bottom: 10rpx;
}

.ticket-body {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.ticket-row {
  display: flex;
}

.ticket-label {
  width: 220rpx;
  font-size: 30rpx;
  color: #111827;
  font-weight: 700;
}

.ticket-value {
  font-size: 30rpx;
  color: #111827;
  font-weight: 700;
  flex: 1;
  padding-left: 12rpx;
  word-break: break-all;
}

.ticket-qr {
  margin-top: 22rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.ticket-qr-label {
  font-size: 26rpx;
  color: #111827;
  font-weight: 700;
  margin-bottom: 10rpx;
}

.ticket-qr-image {
  width: 280rpx;
  height: 280rpx;
}

.bottom-actions {
  padding: 16rpx 24rpx 24rpx;
}

.btn-primary {
  width: 100%;
  background-color: #1976d2;
  color: #ffffff;
  border-radius: 32rpx;
  font-size: 28rpx;
}

.empty {
  padding: 40rpx 0;
  align-items: center;
  justify-content: center;
}

.empty-text {
  font-size: 26rpx;
  color: #6b7280;
  text-align: center;
}

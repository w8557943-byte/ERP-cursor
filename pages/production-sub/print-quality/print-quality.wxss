.container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.order-info {
  background: white;
  border-radius: 10rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.1);
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #eee;
}

.order-no {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.order-status {
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.status-pending {
  background-color: #fff3cd;
  color: #856404;
}

.status-pass {
  background-color: #d4edda;
  color: #155724;
}

.status-fail {
  background-color: #f8d7da;
  color: #721c24;
}

.detail-row {
  display: flex;
  margin-bottom: 10rpx;
}

.label {
  width: 180rpx;
  color: #666;
  font-size: 28rpx;
}

.value {
  flex: 1;
  color: #333;
  font-size: 28rpx;
}

.section {
  background: white;
  border-radius: 10rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.1);
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  padding-bottom: 15rpx;
  border-bottom: 1rpx solid #eee;
}

.qc-items {
  margin-bottom: 20rpx;
}

.qc-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.qc-item:last-child {
  border-bottom: none;
}

.item-name {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.item-status {
  width: 100rpx;
  text-align: center;
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  margin-right: 20rpx;
}

.item-actions {
  display: flex;
  gap: 10rpx;
}

.btn-small {
  font-size: 24rpx;
  padding: 8rpx 16rpx;
  border-radius: 6rpx;
}

.btn-pass {
  background-color: #28a745;
  color: white;
}

.btn-fail {
  background-color: #dc3545;
  color: white;
}

.qc-result {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.result-text {
  font-size: 36rpx;
  font-weight: bold;
}

.result-pass {
  color: #28a745;
}

.result-fail {
  color: #dc3545;
}

.btn-primary {
  background-color: #007bff;
  color: white;
  border: none;
  padding: 15rpx 30rpx;
  border-radius: 8rpx;
  font-size: 28rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.toggle-link {
  color: #007bff;
  font-size: 26rpx;
}

.operation-logs {
  margin-top: 20rpx;
}

.log-item {
  display: flex;
  padding: 15rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.log-item:last-child {
  border-bottom: none;
}

.log-time {
  width: 120rpx;
  color: #999;
  font-size: 24rpx;
  margin-right: 20rpx;
}

.log-content {
  flex: 1;
  color: #666;
  font-size: 26rpx;
}

.no-data {
  text-align: center;
  color: #999;
  padding: 30rpx 0;
}
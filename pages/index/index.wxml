<!--pages/index/index.wxml-->
<view class="container">
  <!-- 页面标题 -->
  <view class="header">
    <text class="title">ERP 系统首页</text>
    <view class="refresh-btn" bindtap="onRefresh">
      <text class="refresh-text">{{refreshLoading ? '刷新中...' : '刷新'}}</text>
    </view>
  </view>

  <!-- 加载状态 -->
  <view wx:if="{{loading}}" class="loading-container">
    <text class="loading-text">数据加载中...</text>
  </view>

  <!-- 主要内容 -->
  <view wx:else class="content">
    <!-- 数据概览卡片 -->
    <view class="stats-section">
      <view class="section-title">数据概览</view>
      
      <!-- 订单统计 -->
      <view class="stats-grid">
        <view class="stat-card" bindtap="navigateToOrders">
          <text class="stat-value">{{dashboardStats.totalOrders}}</text>
          <text class="stat-label">总订单数</text>
        </view>
        <view class="stat-card">
          <text class="stat-value">{{dashboardStats.pendingOrders}}</text>
          <text class="stat-label">待处理</text>
        </view>
        <view class="stat-card">
          <text class="stat-value">{{dashboardStats.inProduction}}</text>
          <text class="stat-label">生产中</text>
        </view>
        <view class="stat-card">
          <text class="stat-value">{{dashboardStats.completedOrders}}</text>
          <text class="stat-label">已完成</text>
        </view>
      </view>
    </view>

    <!-- 今日数据 -->
    <view class="today-section">
      <view class="section-title">今日数据</view>
      <view class="today-grid">
        <view class="today-item">
          <text class="today-value">{{todayStats.newOrders}}</text>
          <text class="today-label">新订单</text>
        </view>
        <view class="today-item">
          <text class="today-value">¥{{todayStats.revenueTodayText}}</text>
          <text class="today-label">今日收入</text>
        </view>
        <view class="today-item">
          <text class="today-value">{{todayStats.completedToday}}</text>
          <text class="today-label">今日完成</text>
        </view>
      </view>
    </view>

    <!-- 财务概览 -->
    <view class="finance-section">
      <view class="section-title">财务概览</view>
      <view class="finance-grid">
        <view class="finance-item">
          <text class="finance-value">¥{{financialOverview.totalRevenueText}}</text>
          <text class="finance-label">总收入</text>
        </view>
        <view class="finance-item">
          <text class="finance-value">¥{{financialOverview.accountsReceivableText}}</text>
          <text class="finance-label">应收账款</text>
        </view>
        <view class="finance-item">
          <text class="finance-value">¥{{financialOverview.accountsPayableText}}</text>
          <text class="finance-label">应付账款</text>
        </view>
        <view class="finance-item">
          <text class="finance-value">¥{{financialOverview.profitText}}</text>
          <text class="finance-label">预估利润</text>
        </view>
      </view>
    </view>

    <!-- 最近订单 -->
    <view class="recent-orders-section">
      <view class="section-header">
        <text class="section-title">最近订单</text>
        <text class="view-all" bindtap="navigateToOrders">查看全部</text>
      </view>
      
      <view wx:if="{{recentOrders.length === 0}}" class="empty-state">
        <text class="empty-text">暂无订单数据</text>
      </view>
      
      <view wx:else class="order-list">
        <view wx:for="{{recentOrders}}" wx:key="_id" class="order-item" bindtap="viewOrderDetail" data-id="{{item._id}}">
          <view class="order-info">
            <text class="order-number">{{item.orderNumber || '无编号'}}</text>
            <text class="order-customer">{{item.customerName || '未知客户'}}</text>
          </view>
          <view class="order-status">
            <text class="status-badge status-{{item.status}}">{{item.statusText}}</text>
            <text class="order-amount">¥{{item.totalAmountText}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 快捷操作 -->
    <view class="quick-actions">
      <view class="action-item" bindtap="navigateToOrders">
        <text class="action-icon">📋</text>
        <text class="action-text">订单管理</text>
      </view>
      <view class="action-item" bindtap="navigateToProduction">
        <text class="action-icon">⚙️</text>
        <text class="action-text">生产管理</text>
      </view>
      <view class="action-item" bindtap="navigateToFinance">
        <text class="action-icon">💰</text>
        <text class="action-text">财务管理</text>
      </view>
    </view>
  </view>
</view>

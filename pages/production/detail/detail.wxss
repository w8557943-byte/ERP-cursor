page {
  background: linear-gradient(180deg, #eef2ff 0%, #f8fafc 45%, #f8fafc 100%);
  --primary: #4f46e5;
  --primary2: #06b6d4;
  --text: #0f172a;
  --muted: #64748b;
  --card: #ffffff;
  --stroke: #e2e8f0;
}

.page {
  min-height: 100vh;
  padding: 20rpx 20rpx 0;
  box-sizing: border-box;
}

.header-card {
  background: linear-gradient(135deg, rgba(14, 165, 233, 0.14) 0%, rgba(56, 189, 248, 0.18) 100%);
  border-radius: 16rpx;
  padding: 22rpx 20rpx;
  box-shadow: 0 10rpx 28rpx rgba(14, 165, 233, 0.14);
  border: 1rpx solid rgba(14, 165, 233, 0.22);
}

.header-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.order-no-wrap {
  display: flex;
  align-items: center;
  gap: 14rpx;
  min-width: 0;
}

.order-no {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text);
  max-width: 440rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.copy-link {
  font-size: 24rpx;
  color: #0284c7;
  padding: 8rpx 14rpx;
  background: rgba(255, 255, 255, 0.75);
  border: 1rpx solid rgba(2, 132, 199, 0.25);
  border-radius: 10rpx;
}

.status-badge {
  flex-shrink: 0;
  font-size: 24rpx;
  color: var(--text);
  background: #ffffff;
  border: 1rpx solid rgba(226, 232, 240, 0.9);
  padding: 10rpx 14rpx;
  border-radius: 999rpx;
  box-shadow: 0 10rpx 22rpx rgba(15, 23, 42, 0.08);
}

.status-badge.st-pending {
  background: #ffffff;
  border-color: rgba(245, 158, 11, 0.22);
  color: #b45309;
}

.status-badge.st-processing,
.status-badge.st-in_production {
  background: #ffffff;
  border-color: rgba(59, 130, 246, 0.22);
  color: #1d4ed8;
}

.status-badge.st-stocked {
  background: #ffffff;
  border-color: rgba(34, 197, 94, 0.22);
  color: #15803d;
}

.status-badge.st-shipped,
.status-badge.st-delivered {
  background: #ffffff;
  border-color: rgba(14, 165, 233, 0.22);
  color: #0369a1;
}

.status-badge.st-completed {
  background: #ffffff;
  border-color: rgba(79, 70, 229, 0.22);
  color: #3730a3;
}

.header-sub {
  margin-top: 12rpx;
  display: flex;
  align-items: center;
  color: var(--muted);
  font-size: 26rpx;
}

.header-customer {
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: 30rpx;
  font-weight: 800;
  color: var(--text);
  letter-spacing: 0.4rpx;
}

.state {
  margin-top: 18rpx;
  background: rgba(255, 255, 255, 0.8);
  border-radius: 16rpx;
  padding: 28rpx 20rpx;
  border: 1rpx solid rgba(226, 232, 240, 0.9);
}

.state-text {
  font-size: 28rpx;
  color: var(--text);
}

.state-sub {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #64748b;
}

.stats-grid {
  margin-top: 18rpx;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
}

.stat-card {
  background: rgba(255, 255, 255, 0.86);
  border-radius: 16rpx;
  padding: 18rpx 16rpx;
  border: 1rpx solid rgba(226, 232, 240, 0.9);
  box-shadow: 0 10rpx 26rpx rgba(15, 23, 42, 0.06);
  position: relative;
  overflow: hidden;
}

.stat-card::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  width: 8rpx;
  height: 100%;
  background: linear-gradient(180deg, var(--primary) 0%, var(--primary2) 100%);
  opacity: 0.9;
}

.stat-top {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 8rpx;
}

.stat-icon {
  font-size: 28rpx;
  line-height: 1;
}

.stat-wide {
  grid-column: span 2;
}

.stat-label {
  display: block;
  font-size: 24rpx;
  color: var(--muted);
}

.stat-value {
  display: block;
  font-size: 36rpx;
  font-weight: 800;
  color: var(--text);
}

.stat-value-small {
  font-size: 26rpx;
  font-weight: 600;
  color: #334155;
}

.section-card {
  margin-top: 18rpx;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 16rpx;
  border: 1rpx solid rgba(226, 232, 240, 0.9);
  box-shadow: 0 10rpx 26rpx rgba(15, 23, 42, 0.06);
  overflow: hidden;
}

.section-header {
  padding: 18rpx 18rpx;
  border-bottom: 1rpx solid #f1f5f9;
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 10rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text);
}

.section-sub {
  font-size: 24rpx;
  color: #64748b;
}

.kv-list {
  padding: 12rpx 18rpx 18rpx;
}

.kv-row {
  display: flex;
  gap: 14rpx;
  padding: 12rpx 0;
  border-bottom: 1rpx dashed #e2e8f0;
}

.kv-row:last-child {
  border-bottom: 0;
}

.kv-k {
  width: 160rpx;
  flex-shrink: 0;
  font-size: 26rpx;
  color: #64748b;
}

.kv-v {
  flex: 1;
  font-size: 26rpx;
  color: #0f172a;
  font-weight: 600;
  min-width: 0;
  word-break: break-all;
}

.kv-row-notes .kv-v-notes {
  font-weight: 500;
  color: #334155;
}

.four-progress {
  display: flex;
  gap: 12rpx;
  padding: 18rpx 18rpx 0;
}

.seg {
  flex: 1;
  height: 16rpx;
  background: #e2e8f0;
  border-radius: 999rpx;
  overflow: hidden;
}

.seg-fill {
  height: 100%;
  background: linear-gradient(90deg, #22c55e 0%, #06b6d4 55%, #4f46e5 100%);
}

.steps {
  padding: 14rpx 18rpx 18rpx;
}

.step-item {
  display: flex;
  justify-content: space-between;
  gap: 14rpx;
  background: #f8fafc;
  border: 1rpx solid #eef2f7;
  border-radius: 14rpx;
  padding: 16rpx 14rpx;
  margin-top: 12rpx;
}

.step-left {
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.step-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #0f172a;
}

.step-meta {
  font-size: 24rpx;
  color: #64748b;
}

.step-status {
  flex-shrink: 0;
  align-self: flex-start;
  font-size: 24rpx;
  padding: 8rpx 12rpx;
  border-radius: 999rpx;
  border: 1rpx solid transparent;
}

.step-status.st-pending {
  background: #fff1f2;
  color: #e11d48;
  border-color: #ffe4e6;
}

.step-status.st-done {
  background: #ecfdf5;
  color: #16a34a;
  border-color: #bbf7d0;
}

.shipments {
  padding: 6rpx 18rpx 12rpx;
}

.shipment-row {
  display: flex;
  align-items: baseline;
  gap: 14rpx;
  padding: 10rpx 0;
  border-bottom: 1rpx dashed #e2e8f0;
}

.shipment-row:last-child {
  border-bottom: 0;
}

.shipment-k {
  width: 72rpx;
  flex-shrink: 0;
  font-size: 24rpx;
  color: #64748b;
}

.shipment-v {
  width: 120rpx;
  flex-shrink: 0;
  font-size: 26rpx;
  font-weight: 700;
  color: #0f172a;
}

.shipment-time {
  flex: 1;
  font-size: 24rpx;
  color: #64748b;
}

.drawing-preview {
  padding: 14rpx 18rpx 10rpx;
}

.drawing-image {
  width: 100%;
  border-radius: 14rpx;
  overflow: hidden;
}

.drawing-doc,
.drawing-empty {
  width: 100%;
  padding: 22rpx 16rpx;
  border-radius: 14rpx;
  text-align: center;
  font-size: 26rpx;
  border: 1rpx dashed #cbd5e1;
  background: #f8fafc;
  color: #334155;
}

.attachment-list {
  padding: 0 18rpx 18rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.attachment-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 14rpx 14rpx;
  border-radius: 14rpx;
  background: #f8fafc;
  border: 1rpx solid #eef2f7;
}

.attachment-name {
  font-size: 26rpx;
  color: #0f172a;
  font-weight: 600;
  min-width: 0;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-right: 14rpx;
}

.attachment-tag {
  flex-shrink: 0;
  font-size: 22rpx;
  color: #64748b;
  padding: 6rpx 10rpx;
  background: #ffffff;
  border-radius: 999rpx;
  border: 1rpx solid #e2e8f0;
}

.qc-list {
  padding: 10rpx 18rpx 18rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.qc-item {
  background: #f8fafc;
  border: 1rpx solid #eef2f7;
  border-radius: 14rpx;
  padding: 16rpx 14rpx;
  display: flex;
  justify-content: space-between;
  gap: 14rpx;
}

.qc-k {
  font-size: 26rpx;
  color: #64748b;
}

.qc-v {
  font-size: 26rpx;
  color: #0f172a;
  font-weight: 700;
}

.footer-safe-space {
  height: 130rpx;
}

.footer-area {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(255, 255, 255, 0.88);
  border-top: 1rpx solid rgba(226, 232, 240, 0.9);
  backdrop-filter: blur(18rpx);
  padding: 16rpx 16rpx calc(env(safe-area-inset-bottom) + 16rpx);
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
  row-gap: 12rpx;
  justify-content: flex-end;
  z-index: 100;
}

.btn {
  border-radius: 14rpx;
  padding: 12rpx 18rpx;
  font-size: 26rpx;
  line-height: 1;
  min-width: 140rpx;
}

.btn-primary {
  background: linear-gradient(135deg, var(--primary) 0%, var(--primary2) 100%);
  color: #ffffff;
  box-shadow: 0 12rpx 24rpx rgba(79, 70, 229, 0.28);
}

.btn-ghost {
  background: #f1f5f9;
  color: #0f172a;
}

.dialog-mask {
  position: fixed;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  background: rgba(15, 23, 42, 0.45);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.dialog-panel {
  width: 86%;
  background: #ffffff;
  border-radius: 18rpx;
  padding: 24rpx 20rpx;
  box-shadow: 0 10rpx 26rpx rgba(15, 23, 42, 0.18);
}

.dialog-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #0f172a;
  margin-bottom: 12rpx;
}

.dialog-body {
  margin-bottom: 12rpx;
}

.dialog-row {
  display: flex;
  justify-content: space-between;
  padding: 8rpx 0;
  gap: 12rpx;
}

.dialog-label {
  font-size: 26rpx;
  color: #64748b;
}

.dialog-value {
  font-size: 26rpx;
  color: #0f172a;
  font-weight: 600;
  text-align: right;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.dialog-input-row {
  padding-top: 10rpx;
}

.dialog-input {
  width: 100%;
  border: 1rpx solid #e2e8f0;
  border-radius: 14rpx;
  padding: 14rpx 12rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  background: #ffffff;
}

.dialog-actions {
  display: flex;
  gap: 12rpx;
  justify-content: flex-end;
  margin-top: 14rpx;
}

.btn-primary,
.btn-secondary {
  border-radius: 14rpx;
  padding: 12rpx 18rpx;
  font-size: 26rpx;
  line-height: 1;
}

.btn-secondary {
  background: #f1f5f9;
  color: #0f172a;
}

.inventory-page { padding: 40rpx 30rpx; min-height: 100vh; font-family: 'PingFang SC','Microsoft YaHei','Noto Sans SC','Source Han Sans SC','HarmonyOS Sans','Helvetica Neue',Arial,sans-serif; }
page { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); background-size: 100% 200%; background-repeat: no-repeat; background-position: center top; }
.page-header { padding: 0; margin-bottom: 15rpx; }
.header-card { display: flex; align-items: center; gap: 16rpx; background: rgba(255,255,255,0.95); border-radius: 20rpx; padding: 40rpx; box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.1); }
.header-icon { width: 80rpx; height: 80rpx; background: linear-gradient(135deg, #667eea, #764ba2); border-radius: 16rpx; display: flex; align-items: center; justify-content: center; margin-right: 20rpx; }
.header-icon .icon-text { font-size: 40rpx; color: #fff; }
.main-title { font-size: 36rpx; font-weight: 600; color: #2c3e50; display: block; margin-bottom: 5rpx; }
.sub-title { font-size: 24rpx; color: #6c757d; }

/* 统计卡片网格（参考订单/生产页风格） */
.statistics-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 15rpx;
  margin-bottom: 20rpx;
}

.stat-card {
  background: rgba(255,255,255,0.95);
  border-radius: 12rpx;
  padding: 20rpx 15rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 1rpx 4rpx rgba(0,0,0,0.08);
}

.stat-icon {
  width: 50rpx;
  height: 50rpx;
  border-radius: 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 10rpx;
  font-size: 24rpx;
  color: white;
}

.ordered-icon { background: linear-gradient(135deg, #ab47bc, #9c27b0); }
.waiting-icon { background: linear-gradient(135deg, #ffa726, #ff9800); }
.producing-icon { background: linear-gradient(135deg, #42a5f5, #2196f3); }
.completed-icon { background: linear-gradient(135deg, #43e97b, #38f9d7); }
.urgent-icon { background: linear-gradient(135deg, #ff6b6b, #ee5a52); }

.stat-content { text-align: center; }
.stat-number { font-size: 28rpx; font-weight: 600; color: #2c3e50; display: block; margin-bottom: 2rpx; }
.stat-label { font-size: 20rpx; color: #6c757d; }

/* 搜索栏已移除 */

.filter-container {
  margin: 10rpx 0 20rpx;
  background: rgba(255,255,255,0.95);
  border-radius: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.08);
  overflow: hidden;
}

.view-tabs {
  display: flex;
  border-bottom: 1rpx solid #eee;
}

.view-tab {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: #666;
  background: #f8f9fa;
  transition: all 0.3s;
  position: relative;
}

.view-tab.active {
  color: #fff;
  background: linear-gradient(135deg, #2196F3, #1976D2);
  font-weight: 600;
}

.nav-bar { 
  margin: 0; 
  background: transparent; 
  border-radius: 0; 
  padding: 20rpx; 
  display: flex; 
  align-items: center; 
  justify-content: space-between; 
  box-shadow: none; 
}
.nav-title { font-size: 30rpx; font-weight: 700; color: #333; }
.nav-actions { display: flex; gap: 12rpx; }
.nav-btn { padding: 10rpx 20rpx; border-radius: 12rpx; font-size: 26rpx; background: #eef2ff; color: #333; }
.nav-btn.primary { background: #e0f2fe; color: #0369a1; }

.inventory-list { height: calc(100vh - 380rpx); padding: 0 0 20rpx; }
.empty-state { display: flex; align-items: center; justify-content: center; height: 300rpx; color: #9ca3af; }
.order-cards { display: flex; flex-direction: column; gap: 16rpx; }
.order-card { background: rgba(255, 255, 255, 0.95); border-radius: 16rpx; padding: 30rpx; box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1); transition: transform 0.18s, box-shadow 0.18s; font-family: 'PingFang SC','Microsoft YaHei','Noto Sans SC','Source Han Sans SC','HarmonyOS Sans','Helvetica Neue',Arial,sans-serif; }
.order-card:active { transform: scale(0.98); }
.order-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12rpx; }
.order-number { font-size: 32rpx; font-weight: 600; color: #374151; }
.customer-label { font-size: 32rpx; color: #374151; font-weight: 500; }
.customer-name { font-size: 32rpx; color: #374151; font-weight: 500; }
.order-status { padding: 8rpx 16rpx; border-radius: 12rpx; font-size: 24rpx; font-weight: 500; text-align: center; min-width: 100rpx; }
.status-stocked { background: #d1fae5; color: #059669; }

/* 统一详情行样式 */
.detail-line { margin-bottom: 8rpx; display: flex; align-items: flex-start; line-height: 1.5; }
.detail-label { color: #6b7280; font-size: 28rpx; min-width: 150rpx; }
.detail-value { color: #111827; font-size: 28rpx; flex: 1; word-break: break-all; }

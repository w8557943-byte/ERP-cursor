<view class="inventory-page">
  <view class="page-header">
    <view class="header-card">
      <image class="header-logo" src="/images/logo.png" mode="heightFix"></image>
      <view class="header-info">
        <text class="main-title">用户管理</text>
        <text class="sub-title">管理系统用户账号与角色</text>
      </view>
    </view>
  </view>

  <view class="statistics-grid">
    <view class="stat-card">
      <view class="stat-icon completed-icon">👥</view>
      <view class="stat-content">
        <text class="stat-number">{{total}}</text>
        <text class="stat-label">总用户</text>
      </view>
    </view>
    <view class="stat-card">
      <view class="stat-icon producing-icon">✅</view>
      <view class="stat-content">
        <text class="stat-number">{{activeCount}}</text>
        <text class="stat-label">启用</text>
      </view>
    </view>
    <view class="stat-card">
      <view class="stat-icon urgent-icon">🚫</view>
      <view class="stat-content">
        <text class="stat-number">{{disabledCount}}</text>
        <text class="stat-label">停用</text>
      </view>
    </view>
    <view class="stat-card" bindtap="openCreate">
      <view class="stat-icon waiting-icon">➕</view>
      <view class="stat-content">
        <text class="stat-number">新增</text>
        <text class="stat-label">添加用户</text>
      </view>
    </view>
  </view>

  <view class="filter-container">
    <view class="nav-bar">
      <input class="search-input" placeholder="搜索用户名/姓名/手机号" value="{{keyword}}" bindinput="onKeywordInput" bindconfirm="onSearch" />
      <view class="nav-actions">
        <view class="nav-btn primary" bindtap="onSearch">搜索</view>
      </view>
    </view>
  </view>

  <scroll-view class="inventory-list" scroll-y refresher-enabled="{{true}}" refresher-triggered="{{loading}}" bindrefresherrefresh="onPullDownRefresh" bindscrolltolower="onReachBottom">
    <view wx:if="{{!loading && (!users || users.length === 0)}}" class="empty-state">
      <text class="empty-text">暂无用户数据</text>
    </view>
    <view wx:else class="order-cards">
      <view wx:for="{{users}}" wx:key="_id" class="order-card">
        <view class="order-header">
          <view class="order-info">
            <view class="order-number-row" style="display: flex; align-items: center; gap: 10rpx;">
               <text class="order-number">{{item.name || item.realName || item._displayName}}</text>
               <text class="user-super" wx:if="{{item._isSuperAdmin}}" style="font-size: 20rpx; padding: 2rpx 8rpx; background: #fff7ed; color: #c2410c; border: 1rpx solid #ffedd5; border-radius: 6rpx;">超管</text>
            </view>
          </view>
          <view class="right-column">
            <view class="order-status {{item.status === 'active' ? 'status-stocked' : 'status-urgent'}}">
              {{item.status === 'active' ? '启用' : '停用'}}
            </view>
          </view>
        </view>
        <view class="order-details">
          <view class="detail-line"><text class="detail-label">账号：</text><text class="detail-value">{{item.username || '-'}}</text></view>
          <view class="detail-line" wx:if="{{item._showPhone}}"><text class="detail-label">手机号：</text><text class="detail-value">{{item.phone}}</text></view>
          <view class="detail-line"><text class="detail-label">角色名称：</text><text class="detail-value">{{item._roleText}}</text></view>
          <view class="detail-line" style="margin-top: 20rpx; gap: 20rpx; justify-content: flex-end;">
            <button class="action-btn" size="mini" bindtap="openEdit" data-index="{{index}}" style="background: #4f46e5; color: white;">编辑</button>
            <button class="action-btn danger" size="mini" bindtap="onDeleteUser" data-index="{{index}}" style="background: #ef4444; color: white;">删除</button>
          </view>
        </view>
      </view>
    </view>
    <view class="list-loading" wx:if="{{loading}}">加载中...</view>
    <view class="list-nomore" wx:if="{{!loading && users && users.length > 0 && !hasMore}}">没有更多了</view>
  </scroll-view>
</view>

<view class="modal-mask" wx:if="{{formVisible}}" bindtap="closeForm">
  <view class="modal-card" catchtap="stop">
    <view class="modal-header">
      <text class="modal-title">{{formMode === 'create' ? '新增用户' : '编辑用户'}}</text>
      <text class="modal-sub">{{formMode === 'create' ? '创建新账号并分配权限' : '修改账号信息与权限'}}</text>
    </view>

    <view class="modal-body">
      <view class="form-item">
        <text class="form-label">用户名称</text>
        <input class="form-input" placeholder="请输入用户名称" value="{{form.name}}" bindinput="onFormInput" data-field="name" />
      </view>

      <view class="form-item">
        <text class="form-label">登入账号</text>
        <input class="form-input" placeholder="请输入登入账号" value="{{form.username}}" bindinput="onFormInput" data-field="username" />
      </view>

      <view class="form-item">
        <text class="form-label">手机号</text>
        <input class="form-input" placeholder="请输入手机号" type="number" inputmode="numeric" maxlength="11" value="{{form.phone}}" bindinput="onFormInput" data-field="phone" />
      </view>

      <view class="form-item">
        <text class="form-label">登入密码</text>
        <input class="form-input" password="true" placeholder="{{formMode === 'create' ? '至少6位' : '留空不修改'}}" value="{{form.password}}" bindinput="onFormInput" data-field="password" />
      </view>

      <view class="form-item">
        <text class="form-label">状态</text>
        <view class="switch-row">
          <text class="switch-text">{{form.status === 'active' ? '启用' : '停用'}}</text>
          <switch checked="{{form.status === 'active'}}" color="#4f46e5" bindchange="onStatusSwitch" />
        </view>
      </view>

      <view class="form-item">
        <text class="form-label">权限分配</text>
        <picker class="form-picker" range="{{roleOptions}}" range-key="label" bindchange="onPickRole">
          <view class="picker-inner">
            <text class="picker-text">{{formRoleLabel}}</text>
            <text class="picker-arrow">›</text>
          </view>
        </picker>
      </view>
    </view>

    <view class="modal-footer">
      <button class="footer-btn ghost" size="mini" bindtap="closeForm" disabled="{{formSaving}}">取消</button>
      <button class="footer-btn primary" size="mini" bindtap="submitForm" loading="{{formSaving}}">{{formMode === 'create' ? '创建' : '保存'}}</button>
    </view>
  </view>
</view>

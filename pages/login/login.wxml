<view class="login-page">
  <view class="login-hero">
    <view class="login-hero-content">
      <text class="login-hero-title">荣禾纸箱ERP</text>
      <text class="login-hero-subtitle">欢迎使用，请先登录</text>
    </view>
  </view>

  <view class="login-form">
    <view class="login-form-card">
      <view class="login-mode">
        <view class="login-mode-item {{activeTab==='password'?'active':''}}" bindtap="switchTab" data-tab="password">密码登录</view>
        <view class="login-mode-item {{activeTab==='code'?'active':''}}" bindtap="switchTab" data-tab="code">手机号登录</view>
      </view>

      <view class="login-field">
        <text class="login-field-label">{{activeTab==='code'?'手机号':'账号'}}</text>
        <input
          class="login-field-input"
          type="{{activeTab==='code'?'number':'text'}}"
          inputmode="{{activeTab==='code'?'numeric':'text'}}"
          placeholder="{{activeTab==='code'?'请输入手机号':'请输入账号'}}"
          maxlength="{{activeTab==='code'?11:50}}"
          bindinput="handlePhoneInput"
          value="{{phone}}"
        />
      </view>

      <view class="login-field" wx:if="{{activeTab==='password'}}">
        <text class="login-field-label">密码</text>
        <input
          class="login-field-input"
          password="{{!showPassword}}"
          type="text"
          placeholder="请输入密码"
          bindinput="handlePasswordInput"
          value="{{password}}"
        />
        <view class="login-field-action" bindtap="togglePassword">
          <text>{{showPassword ? '隐藏' : '显示'}}</text>
        </view>
      </view>

      <view class="remember-password" wx:if="{{activeTab==='password'}}" bindtap="toggleRemember" style="margin-top: 10px; display: flex; align-items: center; justify-content: flex-start; padding: 0 10px;">
        <icon type="{{rememberPassword ? 'success' : 'circle'}}" size="16" color="{{rememberPassword ? '#1890ff' : '#ccc'}}" style="margin-right: 5px;"/>
        <text style="color: #666; font-size: 14px;">记住账号</text>
      </view>

      <view class="login-error" wx:if="{{errorMsg}}">{{errorMsg}}</view>

      <button
        wx:if="{{activeTab==='code'}}"
        class="login-primary-btn"
        open-type="getPhoneNumber"
        bindgetphonenumber="handleGetPhoneNumber"
        loading="{{loading}}"
        disabled="{{loading}}"
      >
        {{loading ? '登录中...' : '一键登录'}}
      </button>

      <button
        wx:if="{{activeTab==='password'}}"
        class="login-primary-btn"
        bindtap="handleLogin"
        loading="{{loading}}"
        disabled="{{loading}}"
      >
        {{loading ? '登录中...' : '立即登录'}}
      </button>

      <!-- <view class="login-links">
        <navigator url="#" class="login-link">注册账号</navigator>
        <navigator url="#" class="login-link">忘记密码</navigator>
      </view> -->
      
      <!-- 总是显示数据库工具入口，方便调试和修复 -->
      <!-- <view class="debug-links" style="margin-top: 20px; text-align: center;">
        <text class="login-link" bindtap="goToDbInit" style="color: #999; font-size: 12px;">快速初始化数据库 / 重置管理员</text>
      </view> -->

      <view class="database-init" wx:if="{{showDatabaseInit}}">
        <view class="init-hint">检测到数据库未初始化</view>
        <view class="init-buttons">
          <button class="init-button" bindtap="initDatabase" size="mini">快速初始化</button>
          <button class="init-button" bindtap="goToDbInit" size="mini" type="default">高级工具</button>
        </view>
      </view>
    </view>
  </view>

  <view class="login-footer">
    <text class="login-footer-title">荣禾ERP</text>
    <text class="login-footer-subtitle">专业纸箱生产管理系统</text>
  </view>

  <!-- 底部波浪图案 -->
  <view class="wave-bg">
    <image class="wave-img" src="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 1440 320'%3E%3Cpath fill='%230099ff' fill-opacity='0.2' d='M0,192L48,197.3C96,203,192,213,288,229.3C384,245,480,267,576,250.7C672,235,768,181,864,181.3C960,181,1056,235,1152,234.7C1248,235,1344,181,1392,154.7L1440,128L1440,320L1392,320C1344,320,1248,320,1152,320C1056,320,960,320,864,320C768,320,672,320,576,320C480,320,384,320,288,320C192,320,96,320,48,320L0,320Z'%3E%3C/path%3E%3Cpath fill='%230099ff' fill-opacity='0.4' d='M0,256L48,261.3C96,267,192,277,288,266.7C384,256,480,224,576,213.3C672,203,768,213,864,224C960,235,1056,245,1152,240C1248,235,1344,213,1392,202.7L1440,192L1440,320L1392,320C1344,320,1248,320,1152,320C1056,320,960,320,864,320C768,320,672,320,576,320C480,320,384,320,288,320C192,320,96,320,48,320L0,320Z'%3E%3C/path%3E%3C/svg%3E" mode="widthFix"></image>
  </view>
</view>

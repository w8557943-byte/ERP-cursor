/* 登录页面 - 现代清爽风格 */
page {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  position: relative;
  overflow: hidden;
}

/* 背景装饰元素 */
page::before {
  content: '';
  position: absolute;
  top: -50%;
  left: -50%;
  width: 200%;
  height: 200%;
  background: radial-gradient(circle, rgba(255,255,255,0.1) 1px, transparent 1px);
  background-size: 50rpx 50rpx;
  animation: float 20s ease-in-out infinite;
  z-index: 1;
}

@keyframes float {
  0%, 100% { transform: translateY(0px) rotate(0deg); }
  50% { transform: translateY(-20px) rotate(180deg); }
}

/* 登录卡片容器 */
.login-card-wrapper {
  position: relative;
  z-index: 10;
  width: 100%;
  max-width: 1600rpx;
  padding: 0 120rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.login-card {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 48rpx;
  padding: 50rpx 160rpx;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.1);
  backdrop-filter: blur(20rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.2);
  width: 100%;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
  transition: all 0.3s ease;
  transform: translateY(0);
  min-height: 280rpx;
}

.login-card:hover {
  transform: translateY(-5rpx);
  box-shadow: 0 30rpx 80rpx rgba(0, 0, 0, 0.15);
}

/* Logo 和标题区域 */
.logo-area {
  text-align: center;
  margin-bottom: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100%;
}

.logo-icon-box {
  display: inline-flex;
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 50%;
  margin-bottom: 20rpx;
  align-items: center;
  justify-content: center;
  position: relative;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.3);
  animation: pulse 2s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.05); }
}

.logo-icon-text {
  color: white;
  font-size: 28rpx;
  font-weight: 700;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.2);
}

.main-title {
  color: #2c3e50;
  font-size: 48rpx;
  font-weight: 700;
  letter-spacing: 6rpx;
  word-spacing: 4rpx;
  margin: 0;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.1);
}

/* 登录方式切换标签 */
.login-tabs {
  display: flex;
  background: rgba(248, 249, 250, 0.8);
  border-radius: 12rpx;
  padding: 6rpx;
  margin-bottom: 40rpx;
  width: 100%;
  position: relative;
  backdrop-filter: blur(10rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.3);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.tab {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 32rpx;
  font-weight: 500;
  color: #8892b0;
  border-radius: 8rpx;
  transition: all 0.3s ease;
  position: relative;
  z-index: 2;
  cursor: pointer;
  letter-spacing: 2rpx;
  word-spacing: 2rpx;
}

.tab.active {
  color: #667eea;
  background: rgba(255, 255, 255, 0.9);
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.2);
  font-weight: 600;
  transform: translateY(-1rpx);
}

/* 输入框组 */
.input-group {
  width: 100%;
  margin-bottom: 24rpx;
  position: relative;
  min-height: 88rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.input-field {
  width: 100%;
  height: 80rpx;
  background: rgba(255, 255, 255, 0.8);
  border: 2rpx solid rgba(102, 126, 234, 0.2);
  border-radius: 14rpx;
  padding: 0 20rpx;
  font-size: 30rpx;
  color: #2c3e50;
  box-sizing: border-box;
  transition: all 0.3s ease;
  backdrop-filter: blur(10rpx);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
  letter-spacing: 1.5rpx;
}

.input-field:focus {
  border-color: #667eea;
  box-shadow: 0 0 0 4rpx rgba(102, 126, 234, 0.1), 0 8rpx 20rpx rgba(0, 0, 0, 0.1);
  outline: none;
  transform: translateY(-2rpx);
}

/* 密码输入框特殊样式 */
.password-group {
  position: relative;
  width: 100%;
  min-height: 88rpx;
  display: flex !important;
  align-items: center;
  justify-content: center;
  visibility: visible !important;
  opacity: 1 !important;
}

.password-toggle {
  position: absolute;
  right: 24rpx;
  top: 50%;
  transform: translateY(-50%);
  color: #667eea;
  font-size: 28rpx;
  font-weight: 500;
  z-index: 2;
  cursor: pointer;
  padding: 10rpx 14rpx;
  border-radius: 8rpx;
  transition: all 0.2s ease;
  letter-spacing: 1rpx;
}

.password-toggle:hover {
  background: rgba(102, 126, 234, 0.1);
  color: #5a67d8;
}

/* 验证码输入框 */
.code-input-field {
  width: 100%;
  height: 80rpx;
  background: rgba(255, 255, 255, 0.8);
  border: 2rpx solid rgba(102, 126, 234, 0.2);
  border-radius: 14rpx;
  padding: 0 20rpx;
  font-size: 30rpx;
  color: #2c3e50;
  box-sizing: border-box;
  transition: all 0.3s ease;
  backdrop-filter: blur(10rpx);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
  margin-bottom: 20rpx;
  letter-spacing: 2rpx;
}

.code-input-field:focus {
  border-color: #667eea;
  box-shadow: 0 0 0 4rpx rgba(102, 126, 234, 0.1), 0 8rpx 20rpx rgba(0, 0, 0, 0.1);
  transform: translateY(-2rpx);
  outline: none;
}

/* 错误提示 */
.error-message {
  background: rgba(255, 107, 107, 0.1);
  color: #e53e3e;
  padding: 16rpx 20rpx;
  border-radius: 12rpx;
  font-size: 26rpx;
  font-weight: 500;
  margin-bottom: 24rpx;
  text-align: center;
  border: 2rpx solid rgba(229, 62, 62, 0.2);
  backdrop-filter: blur(10rpx);
  animation: shake 0.5s ease-in-out;
}

@keyframes shake {
  0%, 100% { transform: translateX(0); }
  25% { transform: translateX(-5rpx); }
  75% { transform: translateX(5rpx); }
}

/* 获取验证码文字链接 */
.get-code-text {
  display: block;
  text-align: right;
  color: #667eea;
  font-size: 28rpx;
  font-weight: 600;
  margin-top: 12rpx;
  cursor: pointer;
  transition: all 0.3s ease;
  padding: 14rpx 24rpx;
  border-radius: 12rpx;
  background: rgba(102, 126, 234, 0.1);
  backdrop-filter: blur(10rpx);
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.1);
  border: 1rpx solid rgba(102, 126, 234, 0.2);
  letter-spacing: 1.5rpx;
}

.get-code-text:hover {
  color: #5a67d8;
  background: rgba(102, 126, 234, 0.1);
  transform: translateX(-4rpx);
}

.get-code-text.disabled {
  color: #a0aec0;
  cursor: not-allowed;
  background: none;
  transform: none;
}

/* 登录按钮 */
.login-button {
  width: 100%;
  height: 80rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  position: relative;
  overflow: hidden;
  color: white;
  border: none;
  border-radius: 14rpx;
  font-size: 32rpx;
  font-weight: 600;
  letter-spacing: 4rpx;
  word-spacing: 3rpx;
  margin: 32rpx 0 24rpx 0;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.4);
  position: relative;
  overflow: hidden;
}

.login-button::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
  transition: left 0.5s;
}

.login-button:hover::before {
  left: 100%;
}

.login-button:active {
  transform: translateY(2rpx);
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.4);
}

/* 忘记密码 */
.forgot-password {
  text-align: center;
  margin-top: 20rpx;
}

.forgot-link {
  color: #667eea;
  font-size: 28rpx;
  font-weight: 500;
  text-decoration: none;
  transition: all 0.3s ease;
  padding: 14rpx 24rpx;
  border-radius: 12rpx;
  background: rgba(102, 126, 234, 0.1);
  backdrop-filter: blur(10rpx);
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.1);
  margin-bottom: 32rpx;
  display: inline-block;
  letter-spacing: 1.5rpx;
}

.forgot-link:hover {
  color: #5a67d8;
  background: rgba(102, 126, 234, 0.1);
  transform: translateY(-2rpx);
}

/* 底部信息 */
.footer-info {
  position: absolute;
  bottom: 40rpx;
  text-align: center;
  color: rgba(255, 255, 255, 0.8);
  font-size: 24rpx;
  font-weight: 400;
  z-index: 10;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.3);
  padding: 18rpx 28rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 12rpx;
  backdrop-filter: blur(10rpx);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  letter-spacing: 1rpx;
}

/* 密码输入样式优化 */
.password-group {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.input-label {
  color: #4a5568;
  font-size: 28rpx;
}

.password-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.password-row .input-field {
  flex: 1;
}

.password-toggle {
  color: #667eea;
  font-size: 26rpx;
  padding: 10rpx 20rpx;
  border-radius: 12rpx;
  background: rgba(102, 126, 234, 0.1);
}

/* 响应式设计 */
@media screen and (max-width: 750rpx) {
  .login-card-wrapper {
    max-width: 95%;
    padding: 0 50rpx;
  }
  
  .login-card {
    padding: 40rpx 80rpx;
    border-radius: 36rpx;
    min-height: 220rpx;
  }
  
  .main-title {
    font-size: 36rpx;
    letter-spacing: 4rpx;
    word-spacing: 3rpx;
  }
  
  .logo-icon-box {
    width: 70rpx;
    height: 70rpx;
  }
  
  .logo-icon-text {
    font-size: 22rpx;
  }
  
  .input-field,
  .code-input-field {
    height: 72rpx;
    font-size: 28rpx;
    padding: 0 16rpx;
    letter-spacing: 1rpx;
  }
  
  .tab {
    font-size: 28rpx;
    padding: 16rpx 0;
    letter-spacing: 1.5rpx;
    word-spacing: 1.5rpx;
  }
  
  .input-group {
    min-height: 80rpx;
  }
  
  .password-group {
    min-height: 80rpx;
  }
  
  .login-button {
    height: 72rpx;
    font-size: 30rpx;
    letter-spacing: 3rpx;
    word-spacing: 2rpx;
  }
  
  .footer-info {
    font-size: 20rpx;
    padding: 14rpx 22rpx;
    letter-spacing: 0.8rpx;
  }
}

/* 错误提示样式 */
.error-message {
  color: #e74c3c;
  font-size: 22rpx;
  margin-top: 12rpx;
  text-align: center;
  background: #fdf2f2;
  border: 1rpx solid #fecaca;
  border-radius: 4rpx;
  padding: 12rpx 16rpx;
  animation: shake 0.3s ease-in-out;
}

@keyframes shake {
  0%, 100% { transform: translateX(0); }
  25% { transform: translateX(-8rpx); }
  75% { transform: translateX(8rpx); }
}

page {
  background: #ffffff;
  min-height: 100vh;
  overflow: hidden;
  display: block;
  padding: 0;
  margin: 0;
}

page::before {
  display: none;
}

.login-page {
  min-height: 100vh;
  background: #ffffff;
  width: 100%;
  position: relative;
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
  overflow: hidden;
}

.login-hero {
  position: relative;
  height: 520rpx;
  background: linear-gradient(135deg, #4f7bff 0%, #6a5cff 45%, #2bd9ff 100%);
  overflow: hidden;
  width: 100%;
}

.login-hero::before {
  content: '';
  position: absolute;
  left: -30%;
  bottom: -340rpx;
  width: 980rpx;
  height: 600rpx;
  background: rgba(255, 255, 255, 0.98);
  border-radius: 50%;
}

.login-hero::after {
  content: '';
  position: absolute;
  right: -35%;
  bottom: -380rpx;
  width: 1060rpx;
  height: 660rpx;
  background: rgba(255, 255, 255, 1);
  border-radius: 50%;
}

.login-hero-content {
  position: relative;
  z-index: 2;
  padding-top: 120rpx;
  text-align: center;
  color: #fff;
}

.login-hero-title {
  font-size: 40rpx;
  font-weight: 800;
  display: block;
  letter-spacing: 2rpx;
}

.login-hero-subtitle {
  margin-top: 12rpx;
  font-size: 22rpx;
  opacity: 0.9;
  display: block;
}

.login-form {
  margin-top: -230rpx;
  padding: 46rpx 56rpx 80rpx;
  position: relative;
  z-index: 3;
  background: #ffffff;
  border-radius: 44rpx 44rpx 0 0;
  box-sizing: border-box;
}

.login-form-card {
  background: transparent;
  border-radius: 0;
  box-shadow: none;
  padding: 0;
  min-height: auto;
  display: flex;
  flex-direction: column;
  border: none;
  -webkit-backdrop-filter: none;
  backdrop-filter: none;
  background-image: none;
}

.login-mode {
  display: flex;
  background: #f3f4f6;
  border-radius: 999rpx;
  padding: 8rpx;
  margin-bottom: 28rpx;
}

.login-mode-item {
  flex: 1;
  text-align: center;
  padding: 18rpx 0;
  font-size: 24rpx;
  color: #6b7280;
  border-radius: 999rpx;
}

.login-mode-item.active {
  color: #4f7bff;
  background: #fff;
  box-shadow: 0 10rpx 24rpx rgba(79, 123, 255, 0.18);
  font-weight: 700;
}

.login-field {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 34rpx 0;
  border-bottom: 1rpx solid #eef2f7;
}

.login-field:last-of-type {
  border-bottom: 0;
}

.login-field-label {
  width: 120rpx;
  font-size: 26rpx;
  color: #374151;
}

.login-field-input {
  flex: 1;
  height: 62rpx;
  font-size: 28rpx;
  color: #111827;
}

.login-field-action {
  width: 120rpx;
  height: 62rpx;
  flex: 0 0 120rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  line-height: 62rpx;
  color: #4f7bff;
  border-radius: 14rpx;
  background: rgba(79, 123, 255, 0.10);
  border: 1rpx solid rgba(79, 123, 255, 0.22);
  box-sizing: border-box;
  text-align: center;
  white-space: nowrap;
}

.login-field-action.disabled {
  color: #9ca3af;
  background: rgba(156, 163, 175, 0.12);
  border-color: rgba(156, 163, 175, 0.24);
}

button.login-field-action-btn {
  padding: 0;
}

button.login-field-action-btn::after {
  border: none;
}

.login-error {
  margin-top: 18rpx;
  padding: 16rpx 18rpx;
  font-size: 26rpx;
  color: #dc2626;
  background: #fef2f2;
  border: 1rpx solid #fecaca;
  border-radius: 14rpx;
  text-align: center;
}

.login-primary-btn {
  margin-top: 66rpx;
  width: 100%;
  height: 82rpx;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #6a5cff 0%, #2bd9ff 100%);
  color: #fff;
  font-size: 30rpx;
  font-weight: 700;
  border: none;
}

.login-links {
  margin-top: 44rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.login-link {
  font-size: 24rpx;
  color: #6b7280;
  padding: 10rpx 6rpx;
}

.database-init {
  margin-top: 22rpx;
}

.init-hint {
  font-size: 24rpx;
  color: #6b7280;
  text-align: center;
  margin-bottom: 12rpx;
}

.init-buttons {
  display: flex;
  gap: 12rpx;
  justify-content: center;
}

.init-button {
  border-radius: 999rpx;
}

.login-footer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: calc(18rpx + env(safe-area-inset-bottom));
  text-align: center;
  color: #9ca3af;
  z-index: 10;
  pointer-events: none;
}

.login-footer-title {
  display: block;
  font-size: 24rpx;
  font-weight: 700;
  color: #6b7280;
}

.login-footer-subtitle {
  color: #9ca3af;
  font-size: 24rpx;
  letter-spacing: 2rpx;
  font-weight: 300;
}

/* 底部波浪背景 */
.wave-bg {
  position: absolute;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 320rpx;
  z-index: 5;
  pointer-events: none;
}

.wave-img {
  width: 100%;
  height: 100%;
  display: block;
}

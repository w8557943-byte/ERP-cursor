/* 登录页面 - 全新优化风格 */
page {
  background: linear-gradient(135deg, #e0f7fa, #bbdefb, #90caf9);
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  position: relative;
  overflow: hidden;
}

/* 背景装饰元素 */
.decoration {
  position: absolute;
  border-radius: 50%;
  filter: blur(40px);
  opacity: 0.6;
  z-index: 0;
}

.decoration-1 {
  width: 600rpx;
  height: 600rpx;
  background: linear-gradient(135deg, #4fc3f7, #29b6f6);
  top: -100rpx;
  left: -100rpx;
}

.decoration-2 {
  width: 400rpx;
  height: 400rpx;
  background: linear-gradient(135deg, #81d4fa, #4fc3f7);
  bottom: -100rpx;
  right: -100rpx;
}

/* 登录卡片容器 */
.login-card-wrapper {
  position: relative;
  z-index: 10;
  width: 100%;
  max-width: 700rpx;
  padding: 0 40rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.login-card {
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(15px);
  border-radius: 30rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.6);
  padding: 60rpx 50rpx;
  box-shadow: 0 20rpx 50rpx rgba(33, 150, 243, 0.25);
  width: 100%;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* Logo 和标题区域 */
.logo-area {
  text-align: center;
  margin-bottom: 40rpx;
  margin-top: -40rpx;
}

.logo-icon-box {
  display: inline-flex;
  width: 120rpx;
  height: 120rpx;
  background: linear-gradient(135deg, #4fc3f7, #29b6f6);
  border-radius: 30rpx;
  margin-bottom: 20rpx;
  align-items: center;
  justify-content: center;
  box-shadow: 0 10rpx 20rpx rgba(33, 150, 243, 0.3);
  transform: rotate(45deg);
}

.logo-icon-text {
  font-size: 60rpx;
  color: white;
  transform: rotate(-45deg);
  font-weight: bold;
}

.main-title {
  color: #1565c0;
  font-size: 56rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
  margin-bottom: 15rpx;
  display: block;
}
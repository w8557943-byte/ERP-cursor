.profile-page {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 40rpx 30rpx;
}

/* 用户信息卡片 */
.user-card {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 20rpx;
  padding: 10rpx 40rpx; /* Reduced vertical padding further to 10rpx */
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.1);
  display: flex;
  align-items: center;
  gap: 30rpx;
}

.user-avatar {
  width: 180rpx;
  height: 180rpx;
  background: transparent;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.avatar-image {
  width: 100%;
  height: 100%;
}

.avatar-icon {
  font-size: 60rpx;
  color: white;
}

.user-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.user-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.user-role {
  font-size: 26rpx;
  color: #666;
}

.user-department {
  font-size: 24rpx;
  color: #999;
}

.user-company {
  font-size: 24rpx;
  color: #7c3aed;
}

.user-stats {
  display: flex;
  flex-direction: column;
  gap: 15rpx;
}

.stat-item {
  text-align: center;
  background: rgba(102, 126, 234, 0.1);
  border-radius: 12rpx;
  padding: 15rpx 20rpx;
  min-width: 80rpx;
}

.stat-number {
  font-size: 24rpx;
  font-weight: bold;
  color: #667eea;
  display: block;
}

.stat-label {
  font-size: 20rpx;
  color: #666;
  display: block;
}

/* 功能菜单 */
.menu-section {
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: white;
  margin-bottom: 20rpx;
  display: block;
}

.menu-list {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
}

.inline-form {
  padding: 0 30rpx 30rpx;
  background: rgba(255, 255, 255, 0.95);
  border-bottom: 1rpx solid #f0f0f0;
}

.menu-item {
  display: flex;
  align-items: center;
  gap: 30rpx;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
  transition: background-color 0.2s;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background: rgba(0, 0, 0, 0.05);
}

.menu-item.disabled {
  opacity: 0.5;
  pointer-events: none;
}

.menu-icon {
  font-size: 36rpx;
  width: 60rpx;
  text-align: center;
}

.menu-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 5rpx;
}

.menu-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.menu-description {
  font-size: 24rpx;
  color: #666;
}

.menu-badge {
  min-width: 44rpx;
  height: 44rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  background: #ef4444;
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.menu-arrow {
  font-size: 32rpx;
  color: #999;
}

.notification-panel {
  background: rgba(255, 255, 255, 0.92);
  border-bottom: 1rpx solid #f0f0f0;
  padding: 0 30rpx 22rpx;
}

.notification-loading,
.notification-empty {
  padding: 14rpx 18rpx;
  color: #6b7280;
  font-size: 26rpx;
  background: #f8fafc;
  border: 1rpx solid #e5e7eb;
  border-radius: 14rpx;
}

.notification-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 18rpx;
  background: #f8fafc;
  border: 1rpx solid #e5e7eb;
  border-radius: 14rpx;
  margin-top: 12rpx;
}

.notification-title {
  font-size: 26rpx;
  color: #111827;
  font-weight: 600;
}

.notification-count {
  min-width: 52rpx;
  height: 44rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: #4f46e5;
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 系统信息 */
.info-section {
  margin-bottom: 30rpx;
}

.info-card {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
}

.info-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.info-item:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 26rpx;
  color: #666;
}

.info-value {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
}

.device-section {
  margin-bottom: 30rpx;
}

.device-card {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 16rpx;
  padding: 24rpx 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.device-info {
  flex: 1;
}

.device-status {
  font-size: 26rpx;
  color: #333;
}

.device-btn {
  padding: 16rpx 32rpx;
  border-radius: 32rpx;
  background-color: #ffffff;
  color: #1976d2;
  border: 2rpx solid #1976d2;
  font-size: 26rpx;
}

.profile-edit-section {
  margin-bottom: 30rpx;
}

.form-card {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 16rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
}

.form-item {
  margin-bottom: 22rpx;
}

.form-item-textarea {
  margin-bottom: 26rpx;
}

.form-label {
  font-size: 26rpx;
  color: #333;
  font-weight: 600;
  display: block;
  margin-bottom: 10rpx;
}

.form-input {
  width: 100%;
  height: 76rpx;
  padding: 0 22rpx;
  background: #f8fafc;
  border: 1rpx solid #e5e7eb;
  border-radius: 14rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  color: #111827;
}

.form-textarea {
  width: 100%;
  min-height: 160rpx;
  padding: 18rpx 22rpx;
  background: #f8fafc;
  border: 1rpx solid #e5e7eb;
  border-radius: 14rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  color: #111827;
}

.form-actions {
  display: flex;
  gap: 14rpx;
}

.radio-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 10rpx 0;
}

.radio-text {
  font-size: 26rpx;
  color: #111827;
}

.picker-value {
  width: 100%;
  height: 76rpx;
  padding: 0 22rpx;
  background: #f8fafc;
  border: 1rpx solid #e5e7eb;
  border-radius: 14rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  color: #111827;
  display: flex;
  align-items: center;
}

.kv-value {
  font-size: 28rpx;
  color: #111827;
  padding: 10rpx 0;
}

.progress-text {
  margin-top: 14rpx;
  text-align: right;
  font-size: 26rpx;
  color: #374151;
}

.form-btn {
  flex: 1;
  height: 76rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0, 0, 0, 0.06);
  color: #111827;
}

.form-btn-primary {
  background: linear-gradient(135deg, #4f46e5 0%, #7c3aed 100%);
  color: #ffffff;
}

/* 退出登录 */
.logout-section {
  display: flex;
  justify-content: center;
  margin-top: 40rpx;
}

.logout-btn {
  width: 300rpx;
  height: 70rpx;
  background: rgba(255, 255, 255, 0.2);
  color: #ffffff;
  border: 1rpx solid rgba(255, 255, 255, 0.35);
  border-radius: 35rpx;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.brand-section {
  margin-top: 26rpx;
  text-align: center;
  padding-bottom: 30rpx;
}

.brand-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #94a3b8;
}

.brand-subtitle {
  display: block;
  margin-top: 6rpx;
  font-size: 24rpx;
  color: #94a3b8;
}

.brand-gap {
  height: 16rpx;
}

.brand-version {
  display: block;
  font-size: 22rpx;
  color: #94a3b8;
}

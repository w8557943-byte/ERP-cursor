.inventory-page { padding: 40rpx 30rpx; min-height: 100vh; font-family: 'PingFang SC','Microsoft YaHei','Noto Sans SC','Source Han Sans SC','HarmonyOS Sans','Helvetica Neue',Arial,sans-serif; }
page { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); background-size: 100% 200%; background-repeat: no-repeat; background-position: center top; }
.page-header { padding: 0; margin-bottom: 15rpx; }
.header-card { display: flex; align-items: center; gap: 16rpx; background: rgba(255,255,255,0.95); border-radius: 20rpx; padding: 40rpx; box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.1); }
.header-logo { height: 80rpx; margin-right: 20rpx; width: auto; display: block; }
.main-title { font-size: 36rpx; font-weight: 600; color: #2c3e50; display: block; margin-bottom: 5rpx; }
.sub-title { font-size: 24rpx; color: #6c757d; }

/* 统计卡片网格 */
.statistics-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 15rpx;
  margin-bottom: 20rpx;
}

.stat-card {
  background: rgba(255,255,255,0.95);
  border-radius: 12rpx;
  padding: 20rpx 15rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 1rpx 4rpx rgba(0,0,0,0.08);
}

.stat-icon {
  width: 50rpx;
  height: 50rpx;
  border-radius: 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 10rpx;
  font-size: 24rpx;
  color: white;
}

.ordered-icon { background: linear-gradient(135deg, #ab47bc, #9c27b0); }
.waiting-icon { background: linear-gradient(135deg, #ffa726, #ff9800); }
.producing-icon { background: linear-gradient(135deg, #42a5f5, #2196f3); }
.completed-icon { background: linear-gradient(135deg, #43e97b, #38f9d7); }
.urgent-icon { background: linear-gradient(135deg, #ff6b6b, #ee5a52); }

.stat-content { text-align: center; }
.stat-number { font-size: 28rpx; font-weight: 600; color: #2c3e50; display: block; margin-bottom: 2rpx; }
.stat-label { font-size: 20rpx; color: #6c757d; }

.filter-container {
  margin: 10rpx 0 20rpx;
  background: rgba(255,255,255,0.95);
  border-radius: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.08);
  overflow: hidden;
}

.nav-bar { 
  margin: 0; 
  background: transparent; 
  border-radius: 0; 
  padding: 20rpx; 
  display: flex; 
  align-items: center; 
  justify-content: space-between; 
  box-shadow: none; 
}

.search-input {
  flex: 1;
  background: #f6f7fb;
  border-radius: 12rpx;
  padding: 10rpx 20rpx;
  font-size: 28rpx;
  margin-right: 20rpx;
}

.nav-actions { display: flex; gap: 12rpx; }
.nav-btn { padding: 10rpx 20rpx; border-radius: 12rpx; font-size: 26rpx; background: #eef2ff; color: #333; }
.nav-btn.primary { background: #e0f2fe; color: #0369a1; }

.inventory-list { height: calc(100vh - 420rpx); padding: 0 0 20rpx; }
.empty-state { display: flex; align-items: center; justify-content: center; height: 300rpx; color: #9ca3af; }
.order-cards { display: flex; flex-direction: column; gap: 16rpx; }
.order-card { background: rgba(255, 255, 255, 0.95); border-radius: 16rpx; padding: 30rpx; box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1); transition: transform 0.18s, box-shadow 0.18s; font-family: 'PingFang SC','Microsoft YaHei','Noto Sans SC','Source Han Sans SC','HarmonyOS Sans','Helvetica Neue',Arial,sans-serif; }
.order-card:active { transform: scale(0.98); }
.order-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12rpx; }
.order-number { font-size: 32rpx; font-weight: 600; color: #374151; }
.order-status { padding: 8rpx 16rpx; border-radius: 12rpx; font-size: 24rpx; font-weight: 500; text-align: center; min-width: 100rpx; }
.status-stocked { background: #d1fae5; color: #059669; }
.status-urgent { background: #fee2e2; color: #b91c1c; }

.detail-line { margin-bottom: 8rpx; display: flex; align-items: flex-start; line-height: 1.5; }
.detail-label { color: #6b7280; font-size: 28rpx; min-width: 150rpx; }
.detail-value { color: #111827; font-size: 28rpx; flex: 1; word-break: break-all; }

/* Modal Styles */
.modal-mask {
  position: fixed;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  background: rgba(15, 23, 42, 0.5);
  display: flex;
  align-items: flex-end;
  justify-content: center;
  padding: 24rpx 20rpx;
  z-index: 1000;
}

.modal-card {
  width: 100%;
  max-width: 720rpx;
  background: rgba(255, 255, 255, 0.98);
  border-radius: 22rpx;
  box-shadow: 0 18rpx 48rpx rgba(0, 0, 0, 0.18);
  overflow: hidden;
}

.modal-header {
  padding: 26rpx 28rpx 18rpx;
  border-bottom: 2rpx solid rgba(17, 24, 39, 0.06);
}

.modal-title {
  font-size: 34rpx;
  font-weight: 800;
  color: #111827;
  display: block;
}

.modal-sub {
  margin-top: 6rpx;
  font-size: 24rpx;
  color: #6b7280;
  display: block;
}

.modal-body {
  padding: 18rpx 28rpx 10rpx;
}

.form-item {
  margin-bottom: 16rpx;
}

.form-label {
  display: block;
  font-size: 24rpx;
  color: #374151;
  margin-bottom: 10rpx;
}

.form-input {
  width: 100%;
  background: #f6f7fb;
  border-radius: 14rpx;
  padding: 18rpx 18rpx;
  font-size: 28rpx;
  color: #111827;
}

.form-picker {
  width: 100%;
}

.switch-row {
  width: 100%;
  background: #f6f7fb;
  border-radius: 14rpx;
  padding: 14rpx 18rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.switch-text {
  font-size: 28rpx;
  color: #111827;
}

.picker-inner {
  width: 100%;
  background: #f6f7fb;
  border-radius: 14rpx;
  padding: 18rpx 18rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.picker-text {
  font-size: 28rpx;
  color: #111827;
}

.picker-arrow {
  font-size: 32rpx;
  color: rgba(17, 24, 39, 0.45);
}

.modal-footer {
  display: flex;
  gap: 14rpx;
  padding: 18rpx 20rpx 22rpx;
  border-top: 2rpx solid rgba(17, 24, 39, 0.06);
}

.footer-btn {
  flex: 1;
  border: none;
  border-radius: 14rpx;
  padding: 14rpx 0;
  font-size: 26rpx;
}

.footer-btn.ghost {
  background: rgba(15, 23, 42, 0.06);
  color: #111827;
}

.footer-btn.primary {
  background: linear-gradient(135deg, #4f46e5 0%, #9333ea 100%);
  color: #ffffff;
}

.list-empty,
.list-loading,
.list-nomore {
  text-align: center;
  padding: 24rpx 0;
  color: #6b7280;
  font-size: 26rpx;
}

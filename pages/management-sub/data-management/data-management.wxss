.dm-page { min-height: 100vh; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); background-size: 100% 200%; background-repeat: no-repeat; background-position: center top; padding-bottom: 60rpx; font-family: 'PingFang SC','Microsoft YaHei','Noto Sans SC','Source Han Sans SC','HarmonyOS Sans','Helvetica Neue',Arial,sans-serif; }

.dm-header { padding: 26rpx 28rpx 10rpx; }
.dm-header-card { display: flex; align-items: center; gap: 16rpx; background: rgba(255,255,255,0.95); border-radius: 20rpx; padding: 26rpx 24rpx; box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.10); }
.dm-header-icon { width: 72rpx; height: 72rpx; background: linear-gradient(135deg, #4f46e5, #7c3aed); border-radius: 16rpx; display: flex; align-items: center; justify-content: center; }
.dm-header-icon-text { font-size: 40rpx; color: #fff; }
.dm-title { font-size: 34rpx; font-weight: 700; color: #111827; display: block; }
.dm-subtitle { font-size: 24rpx; color: #6b7280; display: block; margin-top: 4rpx; }

.dm-nav { padding: 0 18rpx 10rpx; display: flex; gap: 14rpx; }
.dm-nav-item { flex: 1; padding: 18rpx 14rpx; border-radius: 20rpx; background: rgba(255,255,255,0.92); box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.10); border: 1rpx solid rgba(255,255,255,0.55); display: flex; flex-direction: column; align-items: center; gap: 10rpx; }
.dm-nav-icon { width: 88rpx; height: 88rpx; border-radius: 24rpx; display: flex; align-items: center; justify-content: center; box-shadow: 0 10rpx 26rpx rgba(0,0,0,0.10); }
.dm-nav-icon.business { background: linear-gradient(135deg, #60a5fa, #34d399); }
.dm-nav-icon.finance { background: linear-gradient(135deg, #a78bfa, #fb7185); }
.dm-nav-icon-text { font-size: 44rpx; }
.dm-nav-label { font-size: 26rpx; color: #111827; font-weight: 600; }
.dm-nav-item.active { background: rgba(255,255,255,0.98); box-shadow: 0 12rpx 30rpx rgba(0,0,0,0.14); }
.dm-nav-item.active .dm-nav-label { color: #4f46e5; }

.dm-body { padding: 0 18rpx; }
.dm-section { margin-top: 10rpx; }

.dm-card-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 12rpx; }
.dm-stat-card { background: rgba(255,255,255,0.95); border-radius: 16rpx; padding: 18rpx 18rpx; box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.06); }
.dm-stat-label { font-size: 24rpx; color: #6b7280; display: block; }
.dm-stat-value { font-size: 30rpx; font-weight: 700; color: #111827; display: block; margin-top: 10rpx; }

.dm-chart-card { margin-top: 14rpx; background: rgba(255,255,255,0.95); border-radius: 18rpx; padding: 18rpx; box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.06); }
.dm-chart-title { font-size: 30rpx; font-weight: 700; color: #111827; margin-bottom: 12rpx; }
.dm-chart-box { width: 100%; height: 520rpx; border-radius: 14rpx; overflow: hidden; background: #fff; }

.dm-chart-header { display: flex; align-items: center; justify-content: space-between; gap: 12rpx; margin-bottom: 12rpx; }
.dm-chart-header .dm-chart-title { margin-bottom: 0; }
.dm-trend-switch { display: flex; align-items: center; gap: 6rpx; padding: 6rpx; border-radius: 999rpx; background: rgba(243,244,246,0.9); border: 1rpx solid #e5e7eb; }
.dm-trend-item { padding: 8rpx 12rpx; border-radius: 999rpx; font-size: 22rpx; color: #374151; line-height: 1; }
.dm-trend-item.active { color: #fff; background: linear-gradient(135deg, #4f46e5, #7c3aed); }

.dm-list-card { margin-top: 14rpx; background: rgba(255,255,255,0.95); border-radius: 18rpx; padding: 18rpx; box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.06); }
.dm-list-title { font-size: 30rpx; font-weight: 700; color: #111827; margin-bottom: 8rpx; }
.dm-list-empty { padding: 20rpx 0; text-align: center; color: #6b7280; font-size: 26rpx; }
.dm-list-row { display: flex; justify-content: space-between; align-items: center; padding: 18rpx 0; border-top: 1rpx solid #eef2f7; }
.dm-list-row:first-child { border-top: 0; }
.dm-list-left { display: flex; flex-direction: column; gap: 6rpx; }
.dm-list-category { font-size: 28rpx; color: #111827; font-weight: 600; }
.dm-list-date { font-size: 24rpx; color: #6b7280; }
.dm-list-amount { font-size: 28rpx; font-weight: 700; color: #111827; }

@media (max-width: 375px) {
  .dm-chart-box { height: 460rpx; }
  .dm-stat-value { font-size: 28rpx; }
}

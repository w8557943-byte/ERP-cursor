.deploy-test-page {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 40rpx;
}

.header {
  text-align: center;
  margin-bottom: 60rpx;
}

.title {
  font-size: 48rpx;
  color: white;
  font-weight: bold;
  display: block;
  margin-bottom: 20rpx;
}

.subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  display: block;
}

.content {
  background: white;
  border-radius: 20rpx;
  padding: 40rpx;
  margin-bottom: 40rpx;
}

.status-cards {
  display: flex;
  justify-content: space-between;
  margin-bottom: 40rpx;
}

.status-card {
  width: 30%;
  background: #f8f9fa;
  border-radius: 12rpx;
  padding: 30rpx 20rpx;
  text-align: center;
  border: 2rpx solid #e9ecef;
  transition: all 0.3s ease;
}

.status-card.success {
  border-color: #28a745;
  background: #d4edda;
}

.status-card.error {
  border-color: #dc3545;
  background: #f8d7da;
}

.status-card.testing {
  border-color: #ffc107;
  background: #fff3cd;
  animation: pulse 1.5s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.7; }
}

.card-title {
  font-size: 32rpx;
  color: #495057;
  font-weight: bold;
  display: block;
  margin-bottom: 10rpx;
}

.card-status {
  font-size: 28rpx;
  color: #6c757d;
  display: block;
}

.buttons-section {
  margin-bottom: 40rpx;
}

.main-test-btn {
  width: 100%;
  height: 80rpx;
  background: linear-gradient(135deg, #28a745 0%, #20c997 100%);
  color: white;
  border: none;
  border-radius: 12rpx;
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 30rpx;
}

.main-test-btn:disabled {
  background: #6c757d;
  opacity: 0.6;
}

.sub-buttons {
  display: flex;
  justify-content: space-between;
  margin-bottom: 30rpx;
}

.sub-btn {
  width: 31%;
  height: 60rpx;
  background: #007bff;
  color: white;
  border: none;
  border-radius: 8rpx;
  font-size: 24rpx;
}

.sub-btn:disabled {
  background: #6c757d;
  opacity: 0.6;
}

.guide-btn {
  width: 100%;
  height: 60rpx;
  background: #17a2b8;
  color: white;
  border: none;
  border-radius: 8rpx;
  font-size: 28rpx;
  margin-bottom: 20rpx;
}

.page-test-btn {
  width: 100%;
  height: 70rpx;
  background: linear-gradient(135deg, #ffc107 0%, #ff9800 100%);
  color: white;
  border: none;
  border-radius: 12rpx;
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
  animation: glow 2s ease-in-out infinite;
}

.init-db-btn {
  width: 100%;
  height: 70rpx;
  background: linear-gradient(135deg, #28a745 0%, #20c997 100%);
  color: white;
  border: none;
  border-radius: 12rpx;
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
  animation: glow 2s ease-in-out infinite;
}

@keyframes glow {
  0%, 100% { 
    box-shadow: 0 4rpx 15rpx rgba(40, 167, 69, 0.4);
  }
  50% { 
    box-shadow: 0 8rpx 25rpx rgba(40, 167, 69, 0.6);
  }
}

.clear-btn {
  width: 100%;
  height: 60rpx;
  background: #f8f9fa;
  color: #6c757d;
  border: 1rpx solid #dee2e6;
  border-radius: 8rpx;
  font-size: 28rpx;
}

.result-section {
  background: #f8f9fa;
  border-radius: 12rpx;
  padding: 30rpx;
}

.result-title {
  font-size: 32rpx;
  color: #495057;
  font-weight: bold;
  display: block;
  margin-bottom: 20rpx;
}

.result-content {
  max-height: 400rpx;
  background: white;
  border-radius: 8rpx;
  padding: 20rpx;
}

.result-text {
  font-size: 26rpx;
  color: #495057;
  line-height: 1.6;
  white-space: pre-wrap;
  font-family: 'Courier New', monospace;
}

.footer {
  text-align: center;
}

.back-btn {
  width: 200rpx;
  height: 70rpx;
  line-height: 70rpx;
  border-radius: 35rpx;
  background: rgba(255, 255, 255, 0.2);
  color: white;
  border: 1rpx solid rgba(255, 255, 255, 0.3);
  font-size: 28rpx;
}
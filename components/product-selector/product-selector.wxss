.product-selector {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 1000;
}

.selector-overlay {
  width: 100%;
  height: 100%;
  display: flex;
  justify-content: center;
  align-items: center;
}

.selector-content {
  background-color: #fff;
  border-radius: 16rpx;
  width: 95%;
  max-width: 900rpx;
  max-height: 85vh;
  overflow: hidden;
  box-shadow: 0 10rpx 40rpx rgba(0, 0, 0, 0.2);
  display: flex;
  flex-direction: column;
}

.selector-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #e9ecef;
  background-color: #f8f9fa;
  flex-shrink: 0;
}

.selector-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #2c3e50;
}

.close-btn {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background-color: #e9ecef;
  color: #6c757d;
  font-size: 32rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 筛选栏 */
.filter-bar {
  padding: 20rpx 30rpx;
  background-color: #fff;
  border-bottom: 1rpx solid #e9ecef;
  flex-shrink: 0;
}

.search-box {
  position: relative;
  margin-bottom: 20rpx;
}

.search-input {
  width: 100%;
  height: 80rpx;
  background-color: #f8f9fa;
  border: 1rpx solid #e9ecef;
  border-radius: 40rpx;
  padding: 0 80rpx 0 30rpx;
  font-size: 28rpx;
  color: #2c3e50;
  box-sizing: border-box;
}

.search-input:focus {
  border-color: #667eea;
  background-color: #fff;
}

.search-icon {
  position: absolute;
  right: 30rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 32rpx;
  color: #6c757d;
}

.filter-controls {
  display: flex;
  gap: 20rpx;
}

.filter-picker {
  flex: 1;
  height: 70rpx;
  background-color: #f8f9fa;
  border: 1rpx solid #e9ecef;
  border-radius: 35rpx;
  padding: 0 20rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 26rpx;
}

.filter-text {
  color: #495057;
  flex: 1;
}

.picker-arrow {
  color: #6c757d;
  font-size: 20rpx;
}

/* 产品列表 */
.product-list {
  flex: 1;
  overflow-y: auto;
  padding: 20rpx;
}

.loading, .empty {
  text-align: center;
  padding: 80rpx 0;
  color: #6c757d;
  font-size: 28rpx;
}

.empty-text {
  display: block;
  margin-bottom: 20rpx;
  font-size: 32rpx;
  color: #495057;
}

.empty-tip {
  font-size: 26rpx;
  color: #6c757d;
}

.product-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(300rpx, 1fr));
  gap: 20rpx;
}

.product-card {
  background-color: #fff;
  border: 1rpx solid #e9ecef;
  border-radius: 12rpx;
  overflow: hidden;
  transition: all 0.3s ease;
  cursor: pointer;
}

.product-card:hover {
  border-color: #667eea;
  box-shadow: 0 4rpx 20rpx rgba(102, 126, 234, 0.15);
  transform: translateY(-4rpx);
}

.product-image {
  width: 100%;
  height: 200rpx;
  background-color: #f8f9fa;
  overflow: hidden;
}

.product-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.product-info {
  padding: 20rpx;
}

.product-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #2c3e50;
  margin-bottom: 8rpx;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.product-code {
  font-size: 24rpx;
  color: #6c757d;
  margin-bottom: 12rpx;
  display: block;
}

.product-specs {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 12rpx;
}

.spec-item {
  padding: 4rpx 12rpx;
  background-color: #e9ecef;
  color: #495057;
  font-size: 20rpx;
  border-radius: 12rpx;
}

.product-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.product-category {
  padding: 6rpx 12rpx;
  background-color: #667eea;
  color: white;
  font-size: 22rpx;
  border-radius: 12rpx;
}

.product-unit {
  font-size: 24rpx;
  color: #6c757d;
}

.product-price {
  display: flex;
  align-items: baseline;
  margin-bottom: 12rpx;
}

.price-label {
  font-size: 24rpx;
  color: #6c757d;
  margin-right: 8rpx;
}

.price-value {
  font-size: 32rpx;
  font-weight: bold;
  color: #e74c3c;
}

.price-unit {
  font-size: 20rpx;
  color: #6c757d;
  margin-left: 4rpx;
}

.product-stock {
  display: flex;
  align-items: center;
}

.stock-label {
  font-size: 24rpx;
  color: #6c757d;
  margin-right: 8rpx;
}

.stock-value {
  font-size: 24rpx;
  font-weight: bold;
}

.stock-value.sufficient {
  color: #27ae60;
}

.stock-value.low {
  color: #f39c12;
}

.stock-value.out {
  color: #e74c3c;
}
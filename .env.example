# 荣禾ERP系统 - 环境变量配置模板
# 使用说明：复制此文件为 .env 并填入真实的配置值

# =============================================================================
# 微信云开发基础配置
# =============================================================================

# 微信小程序配置
WECHAT_APPID=your_wechat_appid_here
WECHAT_SECRET=your_wechat_app_secret_here

# 云开发环境配置
CLOUD_ENV_ID=your_cloud_env_id_here
CLOUD_ENV_NAME=荣禾ERP生产环境

# 云开发API配置
CLOUD_API_BASE=https://your-env-id.service.tcloudbase.com
CLOUD_API_KEY=your_cloud_api_key_here

# =============================================================================
# 云函数URL配置 (部署后更新)
# =============================================================================

# 核心云函数URL
ERP_API_URL=https://your-env-id.service.tcloudbase.com/erp-api
DATABASE_INIT_URL=https://your-env-id.service.tcloudbase.com/database-init
DATA_SYNC_URL=https://your-env-id.service.tcloudbase.com/data-sync
API_BRIDGE_URL=https://your-env-id.service.tcloudbase.com/api-bridge
DATABASE_OPS_URL=https://your-env-id.service.tcloudbase.com/database-ops
SYNC_MONITOR_URL=https://your-env-id.service.tcloudbase.com/sync-monitor
WEBSOCKET_MANAGER_URL=https://your-env-id.service.tcloudbase.com/websocket-manager

# =============================================================================
# 数据库配置
# =============================================================================

# 数据库类型选择
USE_CLOUD=true
USE_SQLITE=false
USE_MONGODB=false

# 云数据库配置
CLOUD_DATABASE_ENV=your_cloud_env_id_here

# 本地数据库备用配置 (可选)
SQLITE_DB_PATH=./data/erp.db
MONGODB_URI=mongodb://localhost:27017/erp
MONGODB_DB_NAME=erp_cursor

# =============================================================================
# 同步配置
# =============================================================================

# 实时同步设置
SYNC_INTERVAL=30000
SYNC_BATCH_SIZE=100
SYNC_RETRY_ATTEMPTS=3
SYNC_TIMEOUT=30000

# WebSocket配置
WEBSOCKET_TIMEOUT=300000
WEBSOCKET_RECONNECT_INTERVAL=5000
WEBSOCKET_MAX_RECONNECT_ATTEMPTS=5

# =============================================================================
# API配置
# =============================================================================

# API基础配置
API_VERSION=v1
API_TIMEOUT=30000
API_RATE_LIMIT=1000
API_RATE_WINDOW=60000

# 跨域配置 - 生产环境请限制为特定域名
CORS_ENABLED=true
CORS_ORIGINS=https://yourdomain.com,https://admin.yourdomain.com
CORS_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_HEADERS=Content-Type,Authorization,x-client-platform

# =============================================================================
# 安全配置
# =============================================================================

# JWT配置 - 请使用强密钥（至少32位随机字符串）
JWT_SECRET=your_strong_jwt_secret_key_at_least_32_chars_here
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# 权限控制
ENABLE_PERMISSION_CHECK=true
ENABLE_ROLE_BASED_ACCESS=true
ENABLE_AUDIT_LOG=true

# =============================================================================
# 日志和监控配置
# =============================================================================

# 日志级别: debug, info, warn, error
LOG_LEVEL=info
LOG_FORMAT=json
LOG_FILE_PATH=./logs

# 性能监控
ENABLE_PERFORMANCE_MONITORING=true
MONITORING_INTERVAL=60000
ALERT_THRESHOLD_ERROR_RATE=0.01
ALERT_THRESHOLD_RESPONSE_TIME=2000

# =============================================================================
# 业务配置
# =============================================================================

# 订单配置
ORDER_AUTO_NUMBER=true
ORDER_PREFIX=ERP
ORDER_NUMBER_LENGTH=8

# 客户配置
CUSTOMER_AUTO_ID=true
CUSTOMER_DEFAULT_CREDIT=10000

# 库存配置
INVENTORY_TRACK_ENABLED=true
LOW_STOCK_ALERT_ENABLED=true
LOW_STOCK_THRESHOLD=10

# =============================================================================
# 部署环境配置
# =============================================================================

# 环境标识: development, testing, production
NODE_ENV=production
DEPLOYMENT_ENV=cloud
DEPLOYMENT_VERSION=1.0.0
DEPLOYMENT_TIMESTAMP=2024-11-21T09:15:22Z

# 功能开关
FEATURE_REAL_TIME_SYNC=true
FEATURE_API_BRIDGE=true
FEATURE_DATABASE_INIT=true
FEATURE_WEBSOCKET=true

# =============================================================================
# 第三方服务配置 (可选)
# =============================================================================

# 邮件服务
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
SMTP_FROM=noreply@rongjiahe.tech

# 短信服务
SMS_API_KEY=your_sms_api_key
SMS_API_SECRET=your_sms_api_secret
SMS_SENDER=荣禾ERP

# 文件存储 (如需外部存储)
STORAGE_PROVIDER=cloud
STORAGE_BUCKET=erp-files
STORAGE_REGION=ap-beijing

# =============================================================================
# 开发/调试配置 (仅开发环境使用)
# =============================================================================

# 调试模式 - 生产环境必须设置为 false
DEBUG_MODE=false
ENABLE_REQUEST_LOGGING=false
ENABLE_ERROR_STACK_TRACE=false

# 测试配置
TEST_DATABASE_CLEANUP=true
MOCK_EXTERNAL_SERVICES=false

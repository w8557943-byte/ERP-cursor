{
  "compilerOptions": {
    "target": "es2020",
    "lib": [
      "dom",
      "dom.iterable",
      "es6"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./app/*"
      ],
      "@components/*": [
        "./app/frontend/components/*"
      ],
      "@utils/*": [
        "./app/backend/utils/*"
      ]
    }
  },
  "include": [
    "app/**/*",
    "tests/**/*"
  ],
  "exclude": [
    "node_modules",
    "build",
    "dist",
    "*.js",
    "scripts/*.js"
  ]
}
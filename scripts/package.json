{
  "name": "erp-sync-demo",
  "version": "1.0.0",
  "description": "荣禾ERP数据同步演示脚本",
  "main": "syncDemo.js",
  "type": "module",
  "scripts": {
    "demo": "node syncDemo.js",
    "demo:watch": "nodemon syncDemo.js",
    "demo:prod": "cross-env NODE_ENV=production node syncDemo.js",
    "demo:mock": "cross-env ENABLE_REAL_API=false node syncDemo.js",

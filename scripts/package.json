    "mongoose": "^9.0.0",
    "ws": "^8.14.0"
  },
  "devDependencies": {
    "cross-env": "^7.0.0",
    "nodemon": "^3.0.0"
  },
  "keywords": [
    "ERP",
    "数据同步",
    "演示",

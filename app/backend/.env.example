# 荣禾ERP系统后端环境变量配置示例

# 服务器配置
PORT=3000
NODE_ENV=development

# 前端应用地址
FRONTEND_URL=http://localhost:3001

# JWT配置
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=24h

# 本地数据库配置（主数据源）
SQLITE_DB_PATH=./data/erp-local.db

# 云同步开关（云端仅作为备份）
ENABLE_CLOUD_SYNC=true

# 小程序云开发配置（必填：满足手动同步/备份/下载）
WECHAT_CLOUD_ENV_ID=your-cloud-env-id
TCB_SECRET_ID=your-tcb-secret-id
TCB_SECRET_KEY=your-tcb-secret-key
# 可选 PEM 模式（二选一，不与 TCB_SECRET 同时必填）
# WECHAT_API_KEY_ID=your-api-key-id
# WECHAT_API_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----

# 日志配置
LOG_LEVEL=info

# 文件上传配置
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=10485760

# 邮件配置 (可选)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-email-password

# 生产环境配置示例
# PORT=3000
# NODE_ENV=production
# FRONTEND_URL=https://yourdomain.com
# JWT_SECRET=your-production-secret-key
# SQLITE_DB_PATH=/data/erp/erp-local.db
# ENABLE_CLOUD_SYNC=true
# WECHAT_CLOUD_ENV_ID=prod-env-id
# TCB_SECRET_ID=prod-secret-id
# TCB_SECRET_KEY=prod-secret-key
# LOG_LEVEL=error
